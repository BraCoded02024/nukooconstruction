PORT=5000
DATABASE_URL=postgres://username:password@localhost:5432/nukoo_realestate
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nukoo_realestate

# Production: use a long random string (32+ characters). Required when NODE_ENV=production.
JWT_SECRET=your_jwt_secret_key_here

NODE_ENV=development

# Production only: comma-separated browser origins that may call the API (must match your Next.js site URL).
# Example: ALLOWED_ORIGINS=https://nukoo.com,https://www.nukoo.com
# ALLOWED_ORIGINS=

# Optional — email (leads, etc.)
# EMAIL_HOST=
# EMAIL_PORT=
# EMAIL_USER=
# EMAIL_PASS=

# Optional — Cloudinary (if used for uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
