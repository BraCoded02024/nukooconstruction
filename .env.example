# Public site URL for SEO (sitemap, canonical, Open Graph). No trailing slash.
# Production example: https://nukooconstructionandproperties.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL of the API (must end with /api). Local dev matches the Express server.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production: set to your public API, e.g. https://api.yourdomain.com/api
